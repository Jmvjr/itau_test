#!/bin/bash
# Pre-commit hook: Validar se não há arquivos sensíveis sendo commitados

# Cores
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${YELLOW}🔍 Validando segurança antes do commit...${NC}"

ERRORS=0

# Arquivos sensíveis que NÃO devem ser commitados
FORBIDDEN_PATTERNS=(
    "appsettings.Development.json"
    "appsettings.Local.json"
    "appsettings.*.local.json"
    ".env"
    ".env.local"
    "*.pem"
    "*.key"
    "*.pfx"
)

# Verificar cada padrão
for pattern in "${FORBIDDEN_PATTERNS[@]}"; do
    if git diff --cached --name-only | grep -qE "$pattern"; then
        echo -e "${RED}❌ ERRO: Arquivo sensível detectado: $pattern${NC}"
        ERRORS=$((ERRORS + 1))
    fi
done

# Verificar se há credenciais no código
if git diff --cached | grep -qE "(password|senha|secret|api.key|Authorization.*Bearer)" | grep -v ".md"; then
    echo -e "${YELLOW}⚠️  AVISO: Possível credencial encontrada no código${NC}"
    echo "Verifique: git diff --cached"
    ERRORS=$((ERRORS + 1))
fi

if [ $ERRORS -eq 0 ]; then
    echo -e "${GREEN}✅ Segurança validada! Pode fazer commit.${NC}"
    exit 0
else
    echo -e "${RED}❌ Commit bloqueado por razões de segurança${NC}"
    echo "Para forçar (NÃO RECOMENDADO): git commit --no-verify"
    exit 1
fi
