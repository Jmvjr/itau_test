{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Port=3306;Database=compra_programada;User=root;Password=root123;"
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "TopicIRDedoDuro": "ir-dedo-duro",
    "ProducerTimeoutMs": 10000
  },
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/compra-programada-.txt",
          "rollingInterval": "Day"
        }
      }
    ]
  }
}
